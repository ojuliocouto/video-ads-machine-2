# deps
node_modules/

# assets reais e material de validacao local (NUNCA versionar)
# assets reais (avatar, logos de cliente, roteiros) ficam em _local/ ou nos
# dirs de render, todos ignorados. Nada de asset real na raiz do repo.
_local/
render*/
*.mp4
*.mov

# segredos
.env
.env.*
*.key

# saidas de render / temporarios
renders/
_tmp*/
*.enc
.DS_Store

# excecao: fontes abertas SAO versionadas (OFL/open), sobrescreve o *.png acima nao se aplica a woff2
!fonts/*.woff2
